{
    "name": "wbcom-designs/wb-gamification",
    "description": "Complete gamification plugin for BuddyPress and WordPress. Part of the Reign Stack.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Wbcom Designs",
            "homepage": "https://wbcomdesigns.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "woocommerce/action-scheduler": "^3.8"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "szepeviktor/phpstan-wordpress": "^1.0",
        "phpunit/phpunit": "^11.0",
        "brain/monkey": "^2.0",
        "squizlabs/php_codesniffer": "^3.0",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "WBGam\\": "src/"
        },
        "files": [
            "src/Extensions/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "WBGam\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php -d auto_prepend_file=tests/prepend.php vendor/bin/phpunit --configuration phpunit.xml.dist",
        "test:unit": "php -d auto_prepend_file=tests/prepend.php vendor/bin/phpunit --configuration phpunit.xml.dist --testsuite Unit",
        "phpcs": "@php vendor/bin/phpcs --standard=.phpcs.xml --report=summary",
        "phpcs:fix": "@php vendor/bin/phpcbf --standard=.phpcs.xml",
        "phpstan": "@php vendor/bin/phpstan analyse --memory-limit=512M",
        "ci": "bash bin/local-ci.sh",
        "ci:quick": "bash bin/local-ci.sh --quick",
        "ci:no-journeys": "bash bin/local-ci.sh --no-journeys",
        "journeys": "bash bin/run-journeys.sh",
        "journeys:critical": "bash bin/run-journeys.sh --priority critical",
        "journeys:dry-run": "bash bin/run-journeys.sh --dry-run",
        "coding-rules": "bash bin/coding-rules-check.sh",
        "install-hooks": "git config core.hooksPath bin/git-hooks && echo 'Pre-push hook installed (bypass with SKIP_LOCAL_CI=1)'"
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
