{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wb-gamification/badge-showcase",
	"version": "1.0.0",
	"title": "Badge Showcase",
	"category": "widgets",
	"description": "Display earned badges for a member. Optionally shows locked badges greyed out.",
	"keywords": [
		"badges",
		"achievements",
		"gamification"
	],
	"supports": {
		"html": false
	},
	"attributes": {
		"user_id": {
			"type": "integer",
			"default": 0
		},
		"show_locked": {
			"type": "boolean",
			"default": false
		},
		"category": {
			"type": "string",
			"default": ""
		},
		"limit": {
			"type": "integer",
			"default": 0
		}
	},
	"render": "file:./render.php",
	"textdomain": "wb-gamification",
	"editorScript": "file:./edit.js"
}
