{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wb-gamification/community-challenges",
	"version": "1.0.0",
	"title": "Community Challenges",
	"category": "widgets",
	"description": "Display active community challenges (Pokémon GO style — global counter accumulates as everyone contributes).",
	"keywords": [
		"gamification",
		"community",
		"challenges",
		"global"
	],
	"textdomain": "wb-gamification",
	"attributes": {
		"limit": {
			"type": "integer",
			"default": 0
		},
		"show_progress_bar": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"render": "file:./render.php"
}
