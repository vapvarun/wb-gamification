{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wb-gamification/streak",
	"version": "0.1.0",
	"title": "Streak",
	"category": "widgets",
	"description": "Show a member's current activity streak, longest streak, and optional contribution heatmap.",
	"keywords": [
		"gamification",
		"streak",
		"heatmap",
		"activity",
		"consistency"
	],
	"textdomain": "wb-gamification",
	"attributes": {
		"user_id": {
			"type": "integer",
			"default": 0
		},
		"show_longest": {
			"type": "boolean",
			"default": true
		},
		"show_heatmap": {
			"type": "boolean",
			"default": false
		},
		"heatmap_days": {
			"type": "integer",
			"default": 90
		}
	},
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"render": "file:./render.php",
	"editorScript": "file:./edit.js"
}
