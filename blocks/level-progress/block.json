{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wb-gamification/level-progress",
	"version": "0.1.0",
	"title": "Level Progress",
	"category": "widgets",
	"description": "Show a member's current level, progress bar, and points to next level.",
	"keywords": ["gamification", "level", "progress", "rank", "xp"],
	"textdomain": "wb-gamification",
	"attributes": {
		"user_id": {
			"type": "integer",
			"default": 0
		},
		"show_progress_bar": {
			"type": "boolean",
			"default": true
		},
		"show_next_level": {
			"type": "boolean",
			"default": true
		},
		"show_icon": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"render": "file:./render.php"
}
