{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wb-gamification/redemption-store",
	"version": "1.0.0",
	"title": "Redemption Store",
	"category": "widgets",
	"description": "Member-facing rewards catalog. Lists active redemption items with point cost, stock, and a Redeem button.",
	"keywords": [
		"gamification",
		"redemption",
		"rewards",
		"shop",
		"coupon"
	],
	"textdomain": "wb-gamification",
	"attributes": {
		"limit": {
			"type": "integer",
			"default": 0
		},
		"columns": {
			"type": "integer",
			"default": 3
		},
		"show_balance": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"render": "file:./render.php"
}
