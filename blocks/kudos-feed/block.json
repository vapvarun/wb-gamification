{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wb-gamification/kudos-feed",
	"version": "0.1.0",
	"title": "Kudos Feed",
	"category": "widgets",
	"description": "Display a live feed of recent peer kudos.",
	"keywords": [
		"kudos",
		"recognition",
		"peers",
		"gamification"
	],
	"supports": {
		"html": false
	},
	"attributes": {
		"limit": {
			"type": "integer",
			"default": 10,
			"minimum": 1,
			"maximum": 50
		},
		"show_messages": {
			"type": "boolean",
			"default": true
		}
	},
	"render": "file:./render.php",
	"textdomain": "wb-gamification",
	"editorScript": "file:./edit.js"
}
