{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wb-gamification/points-history",
	"version": "0.5.0",
	"title": "Points History",
	"category": "widgets",
	"description": "Show a member's recent point transactions with action labels and dates.",
	"keywords": [
		"points",
		"history",
		"log",
		"transactions",
		"gamification"
	],
	"supports": {
		"html": false
	},
	"attributes": {
		"user_id": {
			"type": "integer",
			"default": 0
		},
		"limit": {
			"type": "integer",
			"default": 20
		},
		"show_action_label": {
			"type": "boolean",
			"default": true
		}
	},
	"render": "file:./render.php",
	"textdomain": "wb-gamification",
	"editorScript": "file:./edit.js"
}
