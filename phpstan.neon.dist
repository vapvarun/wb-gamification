includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    # Level 5, enforced with ZERO baseline and ZERO suppressed errors.
    #
    # History (2026-05-30): the gate had been silently no-op'ing for months —
    # src/Extensions/functions.php's `exit` killed the CLI autoloader, the
    # config referenced a non-existent `blocks` path, and the run OOM'd at
    # 512M. Once fixed, PHPStan first ran clean and surfaced 1,141 level-9
    # "errors". We did NOT baseline them (that is the blind eye). Instead we
    # fixed every REAL issue at level 5 (type bugs, dead code, a copy-paste
    # duplicate, an incompatible method override, a missing import) and
    # configured the genuine false positives (WP-CLI + third-party runtime
    # symbols) honestly via stubs + ignoreErrors. The codebase is now
    # genuinely clean at level 5 with nothing hidden.
    #
    # Levels 6-9 add "missing iterable value type" + strict mixed-cast checks
    # over WordPress's inherently-mixed core APIs (get_param/$wpdb/get_option).
    # That is type-pedantry, not bugs, and the WP ecosystem norm is level 5-6.
    # Raising the level is a future hardening task, to be done by FIXING (typed
    # array shapes), never by re-introducing a baseline.
    level: 5
    paths:
        - src
        - wb-gamification.php
        - integrations
        - uninstall.php
    excludePaths:
        - tests
        - vendor
        - node_modules
        - dist
        - build
        - audit
        - sdk
    bootstrapFiles:
        - vendor/szepeviktor/phpstan-wordpress/bootstrap.php
    scanFiles:
        # WP-CLI class + functions are only defined when running under WP-CLI;
        # load the stubs so static analysis knows WP_CLI::line/add_command/etc.
        - vendor/php-stubs/wp-cli-stubs/wp-cli-stubs.php
    treatPhpDocTypesAsCertain: false
    inferPrivatePropertyTypeFromConstructor: true
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # WordPress globals + dynamic plugin checks generate noise. Quiet
        # the most common WP-specific patterns; tighten over time.
        - '#Constant (WB_GAM_PATH|WB_GAM_URL|WB_GAM_FILE|WB_GAM_VERSION|WB_GAM_BASENAME) not found#'
        # Action Scheduler is loaded conditionally — its functions are
        # discovered at runtime and may not be visible to static analysis.
        - '#Function as_(enqueue_async_action|schedule_single_action|unschedule_all_actions) not found#'
        # WordPress runtime constants defined by core during a real request but
        # not present in the static stubs (auth cookie name, DB name).
        - '#Constant (LOGGED_IN_COOKIE|DB_NAME) not found#'
        # Third-party integration symbols. Each integrations/*.php file only
        # executes when its host plugin is active, which defines these at
        # runtime. They are intentionally invisible to static analysis.
        - '#Function (wc_get_order|wc_get_orders|bp_core_current_time|bp_get_member_user_id|bp_displayed_user_id|bp_displayed_user_domain|bp_displayed_user_url|bp_core_new_nav_item|bp_core_new_subnav_item|bp_core_load_template|bp_current_action|bp_activity_set_action|groups_get_group|give_get_payment_user_id|give_get_payments|register_graphql_object_type|register_graphql_field) not found#'
        - '#(unknown class|invalid type|on an unknown class) (MeprEvent|MeprUser|LLMS_Quiz_Attempt|LLMS_User_Certificate|LLMS_User_Achievement)#'
