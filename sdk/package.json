{
  "name": "@wbcom/wb-gamification",
  "version": "1.5.3",
  "description": "TypeScript SDK for the WB Gamification REST API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "gen-types": "openapi-typescript ../audit/openapi.json --output src/openapi.d.ts",
    "build": "npm run gen-types && tsc && cp src/openapi.d.ts dist/openapi.d.ts",
    "typecheck": "npm run gen-types && tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["gamification", "wordpress", "api", "sdk", "buddypress"],
  "author": "Wbcom Designs",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/vapvarun/wb-gamification"
  },
  "devDependencies": {
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.0.0"
  }
}
