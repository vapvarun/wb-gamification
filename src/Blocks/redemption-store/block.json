{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wb-gamification/redemption-store",
	"version": "2.0.0",
	"title": "Redemption Store",
	"category": "widgets",
	"description": "Member-facing rewards catalog. Lists active redemption items with point cost, stock, and a Redeem button. Pilot for the Wbcom Block Quality Standard.",
	"keywords": [ "gamification", "redemption", "rewards", "shop", "coupon" ],
	"textdomain": "wb-gamification",
	"attributes": {
		"uniqueId":          { "type": "string",  "default": "" },

		"pointType":        { "type": "string",  "default": "" },

		"limit":             { "type": "integer", "default": 0 },
		"columns":           { "type": "integer", "default": 3 },
		"showBalance":       { "type": "boolean", "default": true },
		"showStock":         { "type": "boolean", "default": true },
		"buttonLabel":       { "type": "string",  "default": "" },
		"emptyMessage":      { "type": "string",  "default": "" },

		"padding":           { "type": "object",  "default": { "top": 24, "right": 24, "bottom": 24, "left": 24 } },
		"paddingTablet":     { "type": "object" },
		"paddingMobile":     { "type": "object" },
		"paddingUnit":       { "type": "string",  "default": "px" },
		"margin":            { "type": "object",  "default": { "top": 0, "right": 0, "bottom": 0, "left": 0 } },
		"marginTablet":      { "type": "object" },
		"marginMobile":      { "type": "object" },
		"marginUnit":        { "type": "string",  "default": "px" },

		"fontSize":          { "type": "number" },
		"fontSizeTablet":    { "type": "number" },
		"fontSizeMobile":    { "type": "number" },
		"fontSizeUnit":      { "type": "string",  "default": "px" },
		"fontFamily":        { "type": "string",  "default": "" },
		"fontWeight":        { "type": "string",  "default": "" },
		"lineHeight":        { "type": "number" },
		"lineHeightUnit":    { "type": "string",  "default": "" },
		"letterSpacing":     { "type": "number" },
		"textTransform":     { "type": "string",  "default": "" },

		"accentColor":       { "type": "string",  "default": "" },
		"accentHoverColor":  { "type": "string",  "default": "" },
		"buttonTextColor":   { "type": "string",  "default": "" },
		"cardBackground":    { "type": "string",  "default": "" },
		"cardBorderColor":   { "type": "string",  "default": "" },

		"boxShadow":         { "type": "boolean", "default": false },
		"shadowHorizontal":  { "type": "number",  "default": 0 },
		"shadowVertical":    { "type": "number",  "default": 4 },
		"shadowBlur":        { "type": "number",  "default": 12 },
		"shadowSpread":      { "type": "number",  "default": 0 },
		"shadowColor":       { "type": "string",  "default": "rgba(0, 0, 0, 0.08)" },

		"borderRadius":      { "type": "object",  "default": { "top": 12, "right": 12, "bottom": 12, "left": 12 } },
		"borderRadiusUnit":  { "type": "string",  "default": "px" },

		"hideOnDesktop":     { "type": "boolean", "default": false },
		"hideOnTablet":      { "type": "boolean", "default": false },
		"hideOnMobile":      { "type": "boolean", "default": false }
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"anchor": true,
		"className": true,
		"interactivity": true
	},
	"editorScript":       "file:./index.js",
	"viewScriptModule":   "file:./view.js",
	"style":              "file:./style-index.css",
	"editorStyle":        "file:./index.css",
	"render":             "file:./render.php"
}
